{
  "name": "vuln-monkey",
  "version": "0.1.3",
  "description": "AI-powered API security fuzzer that uses LLMs to discover logic flaws in your endpoints",
  "main": "dist/cli.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "vuln-monkey": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "security",
    "fuzzer",
    "api",
    "vulnerability",
    "pentesting",
    "llm",
    "ai",
    "openapi"
  ],
  "author": "cdbkk",
  "homepage": "https://github.com/cdbkk/vuln-monkey",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cdbkk/vuln-monkey.git"
  },
  "bugs": {
    "url": "https://github.com/cdbkk/vuln-monkey/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
